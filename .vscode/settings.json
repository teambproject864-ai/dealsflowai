{
  "terminal.integrated.profiles.windows": {
    "PowerShell": {
      "source": "PowerShell",
      "args": [
        "-NoLogo",
        "-NoExit",
        "-Command",
        "$env:Path = 'C:\\Program Files\\Git\\cmd;C:\\Program Files\\nodejs;' + $env:Path"
      ]
    },
    "Windows PowerShell": {
      "path": "C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe",
      "args": [
        "-NoLogo",
        "-NoExit",
        "-Command",
        "$env:Path = 'C:\\Program Files\\Git\\cmd;C:\\Program Files\\nodejs;' + $env:Path"
      ]
    }
  },
  "css.lint.unknownAtRules": "ignore",
  "scss.lint.unknownAtRules": "ignore",

  // ── GitHub Actions IDE extension ────────────────────────────────────────────
  // "Unable to resolve action" warnings are false positives produced by the
  // GitHub.vscode-github-actions extension when it cannot reach api.github.com
  // to validate `uses:` references (expected in sandboxed/offline environments).
  // The workflow YAML is correct and runs without issues on GitHub's runners.
  "github-actions.workflows.pinned.enabled": false,

  // Disable schema-driven action-reference validation for workflow files so the
  // redhat.vscode-yaml LSP does not produce duplicate "unable to resolve" diagnostics.
  "yaml.schemas": {
    "": ["**/.github/workflows/*.yml"]
  }
}
